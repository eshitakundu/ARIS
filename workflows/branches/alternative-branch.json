        "label": "alternativesLLM",
        "model": "openai/gpt-oss-120b",
        "temperature": 0.3,
        "systemInstruction": "You are an alternatives analyst for developer tools.\n\nAnalyse search results and extract direct comparisons and migration signals.\n\nFocus on:\n- Named alternative tools that developers actually switch to\n- Specific reasons why developers choose each alternative over the evaluated tool\n- Direct feature or performance comparisons\n- Migration stories — teams that moved away and why\n\nIgnore generic \"top 10 tools\" listicles and marketing content.\nOnly extract comparisons backed by real developer experience.\nMaximum 4 alternatives.",
        "userMessage": "Tool: $dataExtract.package_name\nContext: $dataExtract.evaluation_context\nResults: $mcpAlternatives.result",
        "batchModeEnabled": false,
        "jsonOutputEnabled": true,
        "jsonOutputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"alternatives\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"name\": {\"type\": \"string\"},\n          \"reason_chosen_over_evaluated_tool\": {\"type\": \"string\"},\n          \"best_for\": {\"type\": \"string\"},\n          \"migration_signals\": {\"type\": \"string\"}\n        }\n      }\n    },\n    \"evaluated_tool_wins_when\": {\"type\": \"string\"},\n    \"evaluated_tool_loses_when\": {\"type\": \"string\"},\n    \"summary\": {\"type\": \"string\"}\n  },\n  \"required\": [\"alternatives\", \"evaluated_tool_wins_when\", \"evaluated_tool_loses_when\", \"summary\"]\n}",
