    {
      "id": "node_1780227444733_tiiwkgkf1",
      "type": "llm",
      "position": {
        "x": 1395,
        "y": 135
      },
      "data": {
        "label": "trajectoryLLM",
        "model": "openai/gpt-oss-120b",
        "temperature": 0.2,
        "systemInstruction": "You are a download trajectory analyst for developer tools.\n\nYou receive raw download statistics from either the npm downloads API or PyPI stats API.\n\nExtract and output:\n- weekly_download_trend: describe the trend in plain language (1-2 sentences)\n- velocity: must be exactly one of \"accelerating\", \"stable\", or \"declining\"\n- peak_period: when downloads were highest (e.g. \"Q3 2024\", \"last 3 months\")\n- summary: 2-3 sentences on what the download data signals about this tool's trajectory\n\nIf npm or PyPI download data is unavailable but Tavily trajectory data is present, use the Tavily results to infer velocity from signals like production usage mentions, company adoption, and community activity.\n\nDo NOT output any numeric scores. Only output velocity as one of the three exact strings above.",
        "userMessage": "Tool: $dataExtract.package_name\nRegistry: $dataExtract.package_registry\nnpm data: $httpNpm.body\nPyPI data: $httpPypi.body\nTavily trajectory data: $mcpTavilyTrajectory.result",
        "batchModeEnabled": false,
        "jsonOutputEnabled": true,
        "jsonOutputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"weekly_download_trend\": {\"type\": \"string\"},\n    \"velocity\": {\"type\": \"string\", \"enum\": [\"accelerating\", \"stable\", \"declining\"]},\n    \"peak_period\": {\"type\": \"string\"},\n    \"summary\": {\"type\": \"string\"}\n  },\n  \"required\": [\"weekly_download_trend\", \"velocity\", \"peak_period\", \"summary\"]\n}",
        "credentialId": "2f9e38cc-5603-4f87-8520-338effdb8e99",
        "isReasoningModel": false,
        "retryEnabled": true,
        "onErrorEnabled": true,
        "active": true
      }
    },
    {
      "id": "node_1780227444733_rnf7nfe9l",
      "type": "pythonExec",
      "position": {
        "x": 1755,
        "y": 120
      },
      "data": {
        "label": "trajectoryCompute",
        "code": "import json, sys\n\nraw = json.load(sys.stdin)\nif isinstance(raw, str):\n    raw = json.loads(raw)\n\nVELOCITY_MAP = {\n    \"accelerating\": 80,\n    \"stable\":       55,\n    \"declining\":    25,\n}\n\nvelocity = (raw.get(\"velocity\") or \"stable\").lower().strip()\nadoption_momentum = VELOCITY_MAP.get(velocity, 50)\n\nresult = {\n    \"weekly_download_trend\": raw.get(\"weekly_download_trend\", \"\"),\n    \"velocity\":              velocity,\n    \"adoption_momentum\":     adoption_momentum,\n    \"peak_period\":           raw.get(\"peak_period\", \"\"),\n    \"summary\":               raw.get(\"summary\", \"\"),\n}\n\nprint(json.dumps(result))",
        "inputExpression": "$trajectoryLLM",
        "timeoutSeconds": 30,
        "active": true
      }
    },
    {
      "id": "node_1780227444733_q0o83ah8k",
